<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="480" prefWidth="640" styleClass="vbox" stylesheets="@css/castlefightarena.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="bts66.anthony.castlefightarena.controllers.ScoresController">
   <children>
      <HBox alignment="CENTER_LEFT" prefHeight="68.0" prefWidth="640.0">
         <children>
            <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
               <children>
                  <Label fx:id="totalCombatsLabel" alignment="CENTER" contentDisplay="CENTER" prefHeight="28.0" prefWidth="189.0" styleClass="title" text=" " />
               </children>
            </HBox>
            <HBox alignment="CENTER" prefHeight="65.0" prefWidth="118.0">
               <children>
                  <ImageView fitHeight="60.0" fitWidth="60.0" onMouseClicked="#refreshAction" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@images/refresh.png" />
                     </image>
                  </ImageView>
               </children>
            </HBox>
            <HBox alignment="TOP_RIGHT" prefHeight="65.0" prefWidth="326.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#onRetour" prefHeight="30.0" prefWidth="49.0" style="-fx-background-color: blue; -fx-font-weight: bold;" text="&lt;&lt;" textFill="WHITE" />
                  <Button mnemonicParsing="false" onAction="#onQuit" prefHeight="30.0" prefWidth="10.0" style="-fx-background-color: red; -fx-font-weight: bold;" text="X" textFill="WHITE" />
               </children>
            </HBox>
         </children></HBox>
      <TableView fx:id="scoresTableView" prefHeight="417.0" prefWidth="640.0">
        <columns>
          <TableColumn fx:id="nomColumn" prefWidth="170.0" text="Personnage" />
          <TableColumn fx:id="victoiresColumn" prefWidth="120.0" text="Victoires" />
            <TableColumn fx:id="defaitesColumn" prefWidth="120.0" text="Défaites" />
            <TableColumn fx:id="totalPVColumn" prefWidth="115.0" text="Total PV" />
            <TableColumn fx:id="ratioColumn" prefWidth="115.0" text="Ratio V/D" />
        </columns>
      </TableView>
   </children>
</VBox>
